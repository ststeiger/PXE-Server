    <TargetFramework>net9.0</TargetFramework>
    <RootNamespace>PXE_Server</RootNamespace>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\DHCPServer\DHCPServer.csproj" />
